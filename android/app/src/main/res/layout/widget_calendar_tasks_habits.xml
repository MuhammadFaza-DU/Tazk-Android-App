          android:layout_marginStart="4dp"
          android:textColor="#1E2E22"
          android:textSize="9sp"
          android:maxLines="1"
          android:ellipsize="end" />
      </LinearLayout>
      <LinearLayout
        android:id="@+id/calendar_habit_row_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="0dp">
        <ImageView
          android:id="@+id/calendar_habit_check_3"
          android:layout_width="12dp"
          android:layout_height="12dp"
          android:src="@drawable/ic_checkbox_unchecked" />
        <TextView
          android:id="@+id/calendar_habit_title_3"
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_weight="1"
          android:layout_marginStart="4dp"
          android:textColor="#1E2E22"
          android:textSize="9sp"
          android:maxLines="1"
          android:ellipsize="end" />
      </LinearLayout>
      <LinearLayout
        android:id="@+id/calendar_habit_row_4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="0dp">
        <ImageView
          android:id="@+id/calendar_habit_check_4"
          android:layout_width="12dp"
          android:layout_height="12dp"
          android:src="@drawable/ic_checkbox_unchecked" />
        <TextView
          android:id="@+id/calendar_habit_title_4"
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_weight="1"
          android:layout_marginStart="4dp"
          android:textColor="#1E2E22"
          android:textSize="9sp"
          android:maxLines="1"
          android:ellipsize="end" />
      </LinearLayout>
      <TextView
        android:id="@+id/calendar_habits_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tidak ada habit"
        android:textColor="#667366"
        android:textSize="8sp"
        android:visibility="gone" />
    </LinearLayout>
  </LinearLayout>

  <TextView
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="1"
    android:text="" />

  <TextView
    android:id="@+id/calendar_go_to_app"
    android:layout_width="match_parent"
    android:layout_height="22dp"
    android:layout_marginTop="5dp"
    android:background="@drawable/widget_go_to_app_button"
    android:gravity="center"
    android:maxLines="1"
    android:text="Go to App"
    android:textColor="#FEFCF3"
    android:textSize="10sp"
    android:textStyle="bold" />
</LinearLayout>
